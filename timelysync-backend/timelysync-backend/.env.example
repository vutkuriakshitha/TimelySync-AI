# Copy this file to `.env` (or set these as real environment variables in your
# hosting platform) before running the backend. Never commit a real `.env`.

# Server
PORT=8080

# MongoDB (Atlas or self-hosted). Must include the database name.
MONGODB_URI=mongodb://localhost:27017/timelysync

# JWT - generate a long random string, e.g. `openssl rand -base64 48`
JWT_SECRET=replace-this-with-a-long-random-secret-of-at-least-32-characters
JWT_EXPIRATION_MS=86400000

# CORS - comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Used to build links inside transactional emails (password reset, etc.)
FRONTEND_URL=http://localhost:3000

# File uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# Rate limiting (auth endpoints)
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_MS=60000

# AI microservice (see /ai-service)
AI_SERVICE_URL=http://localhost:8000
AI_INTERNAL_API_KEY=replace-with-a-shared-secret-matching-the-ai-service

# Email / SMTP (optional - forgot-password degrades gracefully if unset)
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Logging
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_SECURITY=WARN
