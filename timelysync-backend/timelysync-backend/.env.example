# Copy to `.env`. Never commit real secrets.

PORT=8080
MONGODB_URI=mongodb://localhost:27017/timelysync
JWT_SECRET=replace-this-with-a-long-random-secret-of-at-least-32-characters
JWT_EXPIRATION_MS=86400000
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
AI_SERVICE_URL=http://localhost:8000
AI_INTERNAL_API_KEY=replace-with-a-shared-secret-matching-the-ai-service

# -------- EMAIL (forgot-password / welcome) --------
# If MAIL_ENABLED=false (or SMTP fails), the API returns a one-time resetLink
# in the forgot-password response when ALLOW_IN_APP_RESET_FALLBACK=true.
ALLOW_IN_APP_RESET_FALLBACK=true
#
# Option A — Gmail App Password:
#   1) Enable 2-Step Verification
#   2) https://myaccount.google.com/apppasswords → create "TimelySync"
#   3) Paste the 16-character password below (spaces optional)
#
# Option B — Brevo free SMTP (often easier than Gmail):
#   MAIL_HOST=smtp-relay.brevo.com
#   MAIL_PORT=587
#   MAIL_USERNAME=<brevo smtp login>
#   MAIL_PASSWORD=<brevo smtp key>
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_FROM=your-email@gmail.com

LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_SECURITY=WARN
